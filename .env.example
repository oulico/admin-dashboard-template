# Backend API base URL (FastAPI)
# Must be one of the origins listed in the backend's CORSMiddleware allow_origins.
VITE_API_BASE_URL=https://staging-api.pardocs.com

# Set to "true" to use in-memory mock data (no backend required)
VITE_USE_MOCK=true

# OpenAPI schema source for `npm run generate:api` (build-time only, not exposed to the browser).
# Default is the static file committed to the repo — works in air-gapped/CI environments.
# Override ad-hoc to fetch the deployed schema:
#   OPENAPI_SOURCE=https://staging-api.pardocs.com/openapi.json npm run generate:api
OPENAPI_SOURCE=./openapi.json
