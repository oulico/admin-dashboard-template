# Backend API base URL (FastAPI)
# Must be one of the origins listed in the backend's CORSMiddleware allow_origins.
VITE_API_BASE_URL=https://staging-api.pardocs.com

# Set to "true" to use in-memory mock data (no backend required)
VITE_USE_MOCK=true

# OpenAPI schema source for `npm run generate:api` (build-time only, not exposed to the browser).
# Accepts a URL or a local file path. Prefer the deployed backend's /openapi.json.
# Examples:
#   https://staging-api.pardocs.com/openapi.json   # staging (recommended for daily dev)
#   https://api.pardocs.com/openapi.json           # production
#   http://localhost:8000/openapi.json             # local backend
#   ./openapi.json                                 # static file fallback
OPENAPI_SOURCE=https://staging-api.pardocs.com/openapi.json
